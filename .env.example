# Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-super-secret-key-change-this
FLASK_ENV=development
FLASK_DEBUG=False

# MongoDB Configuration
# Primary connection (Atlas or other)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# Optional local fallback if Atlas is unreachable
# When set, the app will try this after Atlas fails
#MONGODB_FALLBACK_URI=mongodb://localhost:27017/Quizgenerator

# OpenAI API (optional, for ChatGPT-quality question generation)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Google Gemini API (optional, for Gemini-quality question generation)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Model Configuration (local fallback when no API key is set)
QUESTION_GEN_MODEL=google/flan-t5-base
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=pdf,txt,docx
